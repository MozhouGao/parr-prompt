# Copy this file to ".env" and fill in the keys you need.
# Do not commit ".env" (it is gitignored).
#
# parr-prompt / parr-web load this file automatically (python-dotenv) from the
# repo root and from the current working directory. You can still use: set -a && source .env && set +a

# --- OpenAI ---
OPENAI_API_KEY=
# Default in code: gpt-5.4-mini. Override:
# OPENAI_DEFAULT_MODEL=gpt-5.4-mini

# --- Google Gemini ---
GOOGLE_API_KEY=

# --- xAI Grok ---
XAI_API_KEY=
# Text default: grok-4-1-fast-non-reasoning. With an image: grok-4-1-fast-reasoning unless you set:
# XAI_IMAGE_MODEL=grok-4-1-fast-reasoning
# Optional: override text default for both unless XAI_IMAGE_MODEL is set for image calls:
# XAI_DEFAULT_MODEL=grok-4-1-fast-non-reasoning

# --- Anthropic Claude ---
ANTHROPIC_API_KEY=

# --- DeepSeek (V3.2: deepseek-chat = non-thinking, deepseek-reasoner = thinking; text-only API) ---
DEEPSEEK_API_KEY=
# DEEPSEEK_DEFAULT_MODEL=deepseek-chat

# --- Moonshot (Kimi) — also used to merge answers when 2+ providers succeed in ensemble mode ---
MOONSHOT_API_KEY=
# Keys from https://platform.moonshot.ai use the default API host (api.moonshot.ai).
# If your key is from the China console, set:
# MOONSHOT_BASE_URL=https://api.moonshot.cn/v1
# Default Kimi model is kimi-k2.5 (text and images). Override all Kimi calls with:
# MOONSHOT_DEFAULT_MODEL=kimi-k2.5
# Legacy alias still read if MOONSHOT_DEFAULT_MODEL is unset: MOONSHOT_VISION_MODEL

# --- Doubao / Volcengine Ark ---
ARK_API_KEY=

# --- Optional: web UI (parr-web) ---
# PORT=8050
# HOST=127.0.0.1
# Use HOST=0.0.0.0 only if you need all interfaces; still open http://127.0.0.1:PORT in the browser.
# DEBUG=0
